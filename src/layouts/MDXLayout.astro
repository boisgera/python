---
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/fira-code/index.css";
import { Icon } from "astro-icon";

interface Author {
  name: string;
  email?: string;
  url?: string;
  affiliation?: string;
  twitter?: string;
  github?: string;
}
interface Frontmatter {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  authors?: Author[];
  license?: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const { title, description, authors } = frontmatter;

const base = import.meta.env.BASE_URL || "/";

export const github = "https://github.com/boisgera/python";
---

<!doctype html>
<html lang="fr">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />
    <meta name="generator" content={Astro.generator} />
    <style is:global>
      html {
        hyphens: auto;
        font-size: 18px;
        line-height: 36px;
        font-family: "Inter Variable", sans-serif;
        padding: 18px;
      }

      p {
        margin-top: 0rem;
        margin-bottom: 2rem;
      }

      a:link, a:visited {
        color: #000000;
      }
      a:hover, a:active {
        color: #2563eb;
      }
      a {
        transition: color 0.15s ease;
      }

      h1 {
        font-size: 2.25rem;
        margin-top: 98px;
      }

      h2 {
        font-size: 1.5rem;
        margin-top: 72px;
      }

      h3 {
        font-size: 1rem;
        margin-top: 36px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        /* font-size: 14px; */
        line-height: 1.5;
        margin-bottom: 3rem;
      }

      thead th {
        /* text-align: left; */
        font-weight: 600;
        padding: 10px 12px;
        border-bottom: 1px solid #e5e7eb;
      }

      tbody td {
        padding: 10px 12px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: top;
      }

      tbody tr:hover {
        background-color: #f9fafb;
      }

      img,
      video {
        margin: auto;
        display: block;
        margin-bottom: 1.5rem;
        box-shadow:
          0 4px 6px -1px rgb(0 0 0 / 0.1),
          0 2px 4px -2px rgb(0 0 0 / 0.1);
      }

      figure {
        margin-bottom: 1.5rem;
      }

      .dull {
        filter: grayscale(60%) brightness(0.85);
        transition: filter 0.3s ease;
      }

      .dull:hover {
        filter: none;
      }

      pre.astro-code {
        /* pre:has(> code) support not there yet */
        border-radius: 0.25rem;
        overflow-x: auto;
        padding: 1rem 2rem;
      }
      :not(pre) > code {
        font-family: "Fira Code Variable", sans-serif;
        background-color: #e2e8f0;
        color: black;
        border-radius: 0.25rem;
        padding: 0rem 0.25rem;
      }
      pre > code {
        line-height: 1rem;
      }
    </style>
    <style>
      main {
        max-width: 768px;
        margin: 3rem auto 1rem auto;
      }

    </style>
<script>
document.querySelectorAll('details').forEach(details => {
  details.addEventListener('click', (e) => {
    const summary = details.querySelector('summary');
    if (!summary) return;

    // If the click is NOT on summary → block it
    if (!summary.contains(e.target)) {
      e.stopPropagation();
      e.preventDefault();
    }
  }, true); // 👈 use capture phase
});
</script>
  <script is:inline>
    MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']]
    }
    };
  </script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/mathjax@4/tex-mml-chtml.js">
  </script>
  </head>
<body>
  <nav>
    <a href={base}><Icon name="python" style="width:2rem;height:2rem;" /></a>
    <a href="https://github.com/boisgera/python"
      ><Icon name="github" style="width:2rem;height:2rem;" /></a
    >
    <main>
      <slot />
    </main>
  </nav>
</body>
</html>
